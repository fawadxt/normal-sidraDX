# Backend (set in Vercel → Settings → Environment Variables)
# Platform fee notice shown in swap UI
# FEE_ROUTER_ADDRESS=0x7e30A7a5E550471dF3c288BA2D3e36e84B0F2A11
SWAP_FEE_RECIPIENT=0xYourFeeWallet
CHAIN_ID=97453
CHAIN_NAME=Sidra Chain
TARGET_TOKEN_ADDRESS=0xE4095a910209D7BE03B55D02F40d4554B1666182
SWAP_SLIPPAGE_BPS=100
SIDRA_SWAP_CONTRACT=0xF4B3E8281e1Af643c6Db379FDE67938a4Ce1F822
SIDRA_SWAP_SLIPPAGE_PARAM=10000

# Frontend (VITE_* vars are baked in at build time)
# VITE_FEE_ROUTER_ADDRESS=0x7e30A7a5E550471dF3c288BA2D3e36e84B0F2A11
VITE_SWAP_FEE_RECIPIENT=0xYourFeeWallet
VITE_APP_URL=https://your-project.vercel.app
# Google Drive share link OR direct APK URL — shows "Download APK" on Android web
# Example: https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
# VITE_APK_DOWNLOAD_URL=
# VITE_WALLETCONNECT_PROJECT_ID=optional
